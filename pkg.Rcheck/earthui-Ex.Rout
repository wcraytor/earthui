> 
> ### Name: fit_earth
> ### Title: Fit an earth model
> ### Aliases: fit_earth
> 
> ### ** Examples
> 
> df <- mtcars
> result <- fit_earth(df, target = "mpg",
+                     predictors = c("cyl", "disp", "hp", "wt"))
> format_summary(result)
$coefficients
         term       mpg
1 (Intercept) 17.314004
2   h(150-hp)  0.079194
3  h(2.77-wt)  7.015163
4  h(wt-3.17) -2.501497

$r_squared
[1] 0.8927351

$gcv
[1] 6.184209

$grsq
[1] 0.8350695

$rss
[1] 120.7853

$n_terms
[1] 4

$n_predictors
[1] 2

$n_obs
[1] 32

$cv_rsq
[1] NA

