> cleanEx()
> nameEx("format_anova")
> ### * format_anova
> 
> flush(stderr()); flush(stdout())
> 
> ### Name: format_anova
> ### Title: Format ANOVA decomposition
> ### Aliases: format_anova
> 
> ### ** Examples
> 
> result <- fit_earth(mtcars, "mpg", c("cyl", "disp", "hp", "wt"))
> format_anova(result)
  term  description variables coefficient
1    1  (Intercept)             17.314004
2    2  h(150 - hp)        hp    0.079194
3    3 h(2.77 - wt)        wt    7.015163
4    4 h(wt - 3.17)        wt   -2.501497
> 
> 
> 
> cleanEx()
> nameEx("format_model_equation")
> ### * format_model_equation
> 
> flush(stderr()); flush(stdout())
> 
> ### Name: format_model_equation
> ### Title: Format earth model as LaTeX equation
> ### Aliases: format_model_equation
> 
> ### ** Examples
> 
> result <- fit_earth(mtcars, "mpg", c("cyl", "disp", "hp", "wt"))
> eq <- format_model_equation(result)
> cat(eq$latex)
\small
\begin{array}{l@{\;=\;\,}l}
  \text{Basis} & {}^{0}g^{0}_{1} \;=\; 17.314 \\[4pt]
  \text{hp} & {}^{0}g^{1}_{1} \;=\; 0.07919402 \cdot \max(0, 150 - \text{hp}) \\[4pt]
  \text{wt} & {}^{0}g^{1}_{2} \;=\; 7.015163 \cdot \max(0, 2.77 - \text{wt}) \\[4pt]
  & \qquad -2.501497 \cdot \max(0, \text{wt} - 3.17)
\end{array}> 
> 
