> 
> ### Name: build_allowed_function
> ### Title: Build an allowed function for earth()
> ### Aliases: build_allowed_function
> 
> ### ** Examples
> 
> mat <- build_allowed_matrix(c("sqft", "bedrooms", "pool"))
> mat["sqft", "pool"] <- FALSE
> mat["pool", "sqft"] <- FALSE
> func <- build_allowed_function(mat)
