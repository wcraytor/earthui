title: "earthUI: Interactive Shiny GUI for the earth Package"
version: 0.5.0
license: AGPL-3.0-or-later
url: "https://github.com/wcraytor/earthUI"
repository-code: "https://github.com/wcraytor/earthUI"
authors:
  - family-names: Craytor
